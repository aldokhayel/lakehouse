# .env.example
# Copy this file to .env and fill in any secrets before running `make up`.
# All values shown here are the defaults used when .env is absent.
#
# Usage:
#   cp .env.example .env
#   # Edit .env as needed, then:
#   make up

# ---------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Ports
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---------------------------------------------------------------------------
# Hive Metastore PostgreSQL backend
# ---------------------------------------------------------------------------
METASTORE_DB_NAME=metastore
METASTORE_DB_USER=hive
METASTORE_DB_PASSWORD=hive
METASTORE_DB_PORT=5432

# ---------------------------------------------------------------------------
# Hive Metastore
# ---------------------------------------------------------------------------
HIVE_METASTORE_PORT=9083

# ---------------------------------------------------------------------------
# Trino query engine
# ---------------------------------------------------------------------------
TRINO_PORT=8080

# ---------------------------------------------------------------------------
# Backend API (Phase 2)
# ---------------------------------------------------------------------------
BACKEND_PORT=8000

# OpenRouter LLM gateway (used by backend for natural-language SQL)
OPENROUTER_API_KEY=your_key_here
OPENROUTER_MODEL=anthropic/claude-sonnet-4-20250514

# ---------------------------------------------------------------------------
# NiFi data ingestion (Phase 3)
# ---------------------------------------------------------------------------
NIFI_PORT=8443
NIFI_USERNAME=admin
# NiFi requires a password of at least 12 characters
NIFI_PASSWORD=adminadminadmin

# ---------------------------------------------------------------------------
# Frontend (Phase 4)
# ---------------------------------------------------------------------------
FRONTEND_PORT=3000

# ---------------------------------------------------------------------------
# ChromaDB vector store (Phase 5)
# ---------------------------------------------------------------------------
CHROMADB_PORT=8500

# ---------------------------------------------------------------------------
# Prometheus monitoring (Phase 6)
# ---------------------------------------------------------------------------
PROMETHEUS_PORT=9090

# ---------------------------------------------------------------------------
# Grafana dashboards (Phase 6)
# ---------------------------------------------------------------------------
GRAFANA_PORT=3002
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
